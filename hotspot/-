openapi: 3.0.3
info:
  title: Webmart Portal API
  version: 1.0.0
  description: Hotspot token-based access control API
paths:
  /accounts/api/:
    get:
      operationId: accounts_api_list
      description: API viewset for user registration and profile.
      tags:
      - accounts
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                type: array
                items:
                  $ref: '#/components/schemas/WebmartUser'
          description: ''
    post:
      operationId: accounts_api_create
      description: Register a new user via API.
      tags:
      - accounts
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/WebmartUser'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/WebmartUser'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/WebmartUser'
        required: true
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '201':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/WebmartUser'
          description: ''
  /accounts/api/{id}/:
    get:
      operationId: accounts_api_retrieve
      description: API viewset for user registration and profile.
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this user.
        required: true
      tags:
      - accounts
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/WebmartUser'
          description: ''
    put:
      operationId: accounts_api_update
      description: API viewset for user registration and profile.
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this user.
        required: true
      tags:
      - accounts
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/WebmartUser'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/WebmartUser'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/WebmartUser'
        required: true
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/WebmartUser'
          description: ''
    patch:
      operationId: accounts_api_partial_update
      description: API viewset for user registration and profile.
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this user.
        required: true
      tags:
      - accounts
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedWebmartUser'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedWebmartUser'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/PatchedWebmartUser'
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/WebmartUser'
          description: ''
    delete:
      operationId: accounts_api_destroy
      description: API viewset for user registration and profile.
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this user.
        required: true
      tags:
      - accounts
      security:
      - cookieAuth: []
      - basicAuth: []
      - {}
      responses:
        '204':
          description: No response body
  /accounts/api/me/:
    get:
      operationId: accounts_api_me_retrieve
      description: Get current user profile.
      tags:
      - accounts
      security:
      - cookieAuth: []
      - basicAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
