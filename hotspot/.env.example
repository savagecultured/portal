# WebMART - Environment Variables
# Copy this file to .env and fill in your values

# Django
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,your-domain.com

# Database (PostgreSQL recommended for production)
# DB_NAME=webmart_db
# DB_USER=webmart_user
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=5432

# Token Settings
REGISTRATION_TOKEN_GRANT=5
TOKEN_DURATION_HOURS=5

# Media Services URLs
# Add the internal IPs/URLs of your media services (from Proxmox LXC containers)
JELLYFIN_URL=http://192.168.x.x:8096
JELLYFIN_LABEL=Movies

NAVIDROME_URL=http://192.168.x.x:4533
NAVIDROME_LABEL=Music

IMMICH_URL=http://192.168.x.x:2283
IMMICH_LABEL=Photos

# Additional Services (JSON format)
# ADDITIONAL_SERVICES=[{"name": "My Service", "url": "http://192.168.x.x:8080", "icon": "📚"}]
# Payment Gateway (Paynow NZ) - Configure to enable payments
# PAYNOW_MERCHANT_ID=12345
# PAYNOW_INTEGRATION_KEY=your-integration-key
# PAYNOW_URL=https://paynow.co.nz/integration
TOKEN_PRICE=0.50
